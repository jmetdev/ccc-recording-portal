# Written by install.sh; shown here for reference / manual runs.
DATA_DIR=/opt/ccc-connector
PORTAL_URL=https://dev.cloudcorecollab.com
CONNECTOR_TOKEN=ccck_replace_with_token_from_portal
# Local shared secret between FreeSWITCH hooks and the connector shim (auto-generated).
INGEST_TOKEN=change-me
# Shared secret between the whisper sidecar and the connector (/api/workers/*).
WORKER_TOKEN=change-me
WHISPER_MODEL=base
TRANSCRIBE=true
# Comma-separated CUCM cluster node IPs (also rendered into FreeSWITCH ACL + dialplan).
CUCM_NODES=10.0.0.10,10.0.0.11
# Optional image tag override for the prebuilt FreeSWITCH image
FS_IMAGE_TAG=latest
