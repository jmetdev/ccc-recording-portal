# Copy to /opt/ccc-recording-portal/.env (chmod 600). CI only updates .env.deploy (IMAGE_TAG).

# --- Postgres ---
POSTGRES_USER=portal
POSTGRES_PASSWORD=          # openssl rand -base64 32
POSTGRES_DB=portal

# --- Portal auth ---
JWT_SECRET=                 # openssl rand -base64 48
INGEST_TOKEN=               # openssl rand -base64 32
WORKER_TOKEN=               # openssl rand -base64 32
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=             # strong password
CRYPTO_KEY=                 # python3 -c 'import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())'

# --- Storage (VPS uses local disk) ---
STORAGE_BACKEND=local
RECORDINGS_HOST_PATH=./runtime/recordings
CORS_ORIGINS=https://recorddev.cloudcorecollab.com,https://dev.cloudcorecollab.com

# --- OIDC / Keycloak (flip OIDC_ENABLED=true at tunnel cutover) ---
OIDC_ENABLED=false
OIDC_ISSUER=https://authdev.cloudcorecollab.com/realms/ccc
OIDC_CLIENT_ID=ccc-portal
OIDC_AUDIENCE=

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=    # openssl rand -base64 24
KEYCLOAK_HOSTNAME=https://authdev.cloudcorecollab.com

# --- Suite portal (tenant provisioning / entitlements) ---
# Emails allowed to use the superadmin console (comma-separated).
SUITE_SUPERADMIN_EMAILS=jeffmetcalf@gmail.com
# Shared secret the recording/fax backends present when calling suite's
# internal service-to-service API.
SUITE_INTERNAL_TOKEN=       # openssl rand -base64 32

# Webex OAuth Integration for Keycloak IdP broker (NOT the Service App)
WEBEX_IDP_CLIENT_ID=
WEBEX_IDP_CLIENT_SECRET=

# --- Webex Service App (org onboarding) ---
WEBEX_SERVICEAPP_ID=
WEBEX_SERVICEAPP_CLIENT_ID=
WEBEX_SERVICEAPP_CLIENT_SECRET=
WEBEX_SERVICEAPP_WEBHOOK_SECRET=
WEBEX_SERVICEAPP_ORG_TOKEN=

# --- Per-tenant connector (Phase K: set WEBEX_CONNECTOR_BACKEND=docker) ---
WEBEX_CONNECTOR_BACKEND=
WEBEX_CONNECTOR_IMAGE=ghcr.io/jmetdev/ccc-recording-portal/webex-connector:dev
WEBEX_CONNECTOR_NETWORK=ccc
WEBEX_CONNECTOR_PORTAL_URL=http://backend:8000
WEBEX_CONNECTOR_DOMAIN=recorddev.cloudcorecollab.com

# --- Deploy tag (CI-managed; can also live in .env.deploy) ---
IMAGE_TAG=dev
