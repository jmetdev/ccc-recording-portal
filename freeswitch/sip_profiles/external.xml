<profile name="external">
  <aliases></aliases>
  <gateways>
    <X-PRE-PROCESS cmd="include" data="external/*.xml"/>
  </gateways>
  <domains>
    <domain name="all" alias="false" parse="true"/>
  </domains>
  <settings>
    <param name="debug" value="0"/>
    <param name="sip-trace" value="no"/>
    <param name="sip-capture" value="no"/>
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="ext-rtp-ip" value="$${external_rtp_ip}"/>
    <param name="ext-sip-ip" value="$${external_sip_ip}"/>
    <param name="sip-port" value="$${external_sip_port}"/>
    <param name="tls" value="$${external_ssl_enable}"/>
    <param name="tls-only" value="false"/>
    <param name="tls-bind-params" value="transport=tls"/>
    <param name="tls-sip-port" value="$${external_tls_port}"/>
    <param name="tls-version" value="$${sip_tls_version}"/>
    <param name="tls-cert-dir" value="/etc/freeswitch/certs"/>
    <param name="inbound-codec-prefs" value="$${global_codec_prefs}"/>
    <param name="outbound-codec-prefs" value="$${outbound_codec_prefs}"/>
    <param name="inbound-codec-negotiation" value="generous"/>
    <param name="inbound-late-negotiation" value="true"/>
    <!-- BIB: avoid session-timer / RTP rewrite issues on near-leg forks from CUCM -->
    <param name="enable-timer" value="false"/>
    <param name="minimum-session-expires" value="1800"/>
    <param name="disable-rtp-auto-adjust" value="false"/>
    <param name="rtp-autoflush-during-bridge" value="true"/>
    <param name="inbound-use-callid-as-uuid" value="false"/>
    <param name="auth-calls" value="false"/>
    <param name="apply-inbound-acl" value="cucm"/>
    <param name="rtp-timeout-sec" value="300"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>
    <param name="record-path" value="$${recordings_dir}"/>
    <param name="record-template" value="${caller_id_number}.${uuid}.${strftime(%Y-%m-%d-%H-%M-%S)}.wav"/>
    <param name="manage-presence" value="false"/>
    <param name="disable-transcoding" value="false"/>
    <param name="NDLB-received-in-nat-reg-contact" value="true"/>
    <param name="NDLB-broken-auth-hash" value="true"/>
    <param name="NDLB-sendrecv-in-session" value="true"/>
  </settings>
</profile>
