<include>
  <context name="public">
    <!-- CUCM BIB recording: destination 1034 from CCM cluster nodes -->
    <extension name="cucm_bib_1034">
      <condition field="destination_number" expression="^1034$"/>
      <condition field="${network_addr}" expression="^172\.25\.100\.(10|11|30|31)$">
        <action application="set" data="bib_refci=${sip_from_x-refci}"/>
        <action application="set" data="bib_far_refci=${sip_from_x-farendrefci}"/>
        <action application="set" data="bib_near_addr=${sip_from_x-nearendaddr}"/>
        <action application="set" data="bib_far_addr=${sip_from_x-farendaddr}"/>
        <action application="set" data="bib_session=${sip_from_x-sessionid}"/>
        <action application="set" data="bib_near_device=${sip_from_x-nearenddevice}"/>
        <action application="set" data="bib_far_device=${sip_from_x-farenddevice}"/>
        <action application="set" data="bib_cisco_guid=${sip_h_Cisco-Guid}"/>
        <action application="set" data="bib_near_name=${caller_id_name}"/>
        <action application="set" data="bib_far_name=${caller_id_name}"/>

        <action application="set" data="bib_refci=${regex(${sip_full_from}|x-refci=([^;>]+)|%1)}" condition="${bib_refci} == ''"/>
        <action application="set" data="bib_near_addr=${regex(${sip_full_from}|x-nearendaddr=([^;>]+)|%1)}" condition="${bib_near_addr} == ''"/>
        <action application="set" data="bib_far_addr=${regex(${sip_full_from}|x-farendaddr=([^;>]+)|%1)}" condition="${bib_far_addr} == ''"/>

        <action application="set" data="bib_leg=${regex(${sip_full_from}|;x-nearend;|near)}"/>
        <action application="set" data="bib_leg=${regex(${sip_full_from}|;x-farend;|far)}" condition="${bib_leg} != near"/>

        <action application="set" data="record_sample_rate=8000"/>
        <action application="set" data="RECORD_STEREO=false"/>
        <action application="set" data="recording_file=$${recordings_dir}/cucm_${bib_refci}_${bib_leg}_${bib_near_addr}-${bib_far_addr}_${strftime(%Y%m%d-%H%M%S)}_${uuid}.wav"/>

        <action application="log" data="CRIT CUCM-BIB-1034 src=${network_addr} leg=${bib_leg} refci=${bib_refci} near=${bib_near_addr} far=${bib_far_addr} file=${recording_file}"/>

        <action application="answer"/>
        <action application="bgsystem" data="/usr/local/sbin/bib-notify-start.sh ${bib_refci} ${bib_near_addr} ${bib_far_addr} ${bib_session}"/>

        <action application="record_session" data="${recording_file}"/>

        <action application="set" data="execute_on_hangup=bgsystem /usr/local/sbin/bib-notify-hangup.sh ${bib_refci}"/>

        <action application="sleep" data="3600000"/>
        <action application="hangup"/>
      </condition>
    </extension>

    <extension name="cucm_bib_1034_reject">
      <condition field="destination_number" expression="^1034$"/>
      <action application="log" data="CRIT CUCM-BIB-1034-REJECTED src=${network_addr} from=${sip_from_user}@${sip_from_host}"/>
      <action application="respond" data="403 Forbidden"/>
    </extension>

    <extension name="cucm_bib_other">
      <condition field="destination_number" expression="^(\d+)$">
        <action application="log" data="CRIT CUCM-BIB-OTHER dst=${destination_number} src=${network_addr} from=${sip_from_user}@${sip_from_host}"/>
        <action application="respond" data="404 Not Found"/>
      </condition>
    </extension>
  </context>
</include>
