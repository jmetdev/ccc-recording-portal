# Portal database
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal
POSTGRES_DB=portal
POSTGRES_PORT=5432

# API / UI
BACKEND_PORT=8000
FRONTEND_PORT=5173
JWT_SECRET=change-me-jwt-secret-min-32-chars!!
WORKER_TOKEN=change-me-worker-token
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_PASSWORD=admin123

# Shared secret with FreeSWITCH hooks.
# Must match PORTAL_INGEST_TOKEN in the ccc-freeswitch-docker .env
INGEST_TOKEN=change-me-ingest-token

# Absolute path to FreeSWITCH recordings on the host (critical for split repos).
# Point this at the FreeSWITCH repo's runtime/recordings directory.
# RECORDINGS_HOST_PATH=/opt/ccc-freeswitch-docker/runtime/recordings

# FreeSWITCH live channel stats (backend runs fs_cli via docker on the host).
# FREESWITCH_FS_CLI=docker exec freeswitch fs_cli

# Optional Whisper worker (docker compose --profile whisper)
WHISPER_MODEL=base
